<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav>
            <a class="nav-link <%= activePage === 'home' ? 'active' : '' %>" href="/">Home</a>
            <a class="nav-link <%= activePage === 'about' ? 'active' : '' %>" href="/about">About</a>
            <a class="nav-link <%= activePage === 'user' ? 'active' : '' %>" href="/user">User</a>
            <a class="nav-link <%= activePage === 'host' ? 'active' : '' %>" href="/host">Host</a>
        </nav>
    </header>

    <main class="page-main">
        <section class="hero">
            <h1>Registered Homes</h1>
            <p>Only homes registered by hosts are shown here.</p>
        </section>

        <section class="house-grid">
            <% if (houses.length === 0) { %>
                <article class="house-card">
                    <h2>No registered homes yet</h2>
                    <p>There are no homes available right now. Ask a host to register a property.</p>
                </article>
            <% } else { %>
                <% houses.forEach((house) => { %>
                    <article class="house-card">
                        <h2><%= house.address %></h2>
                        <p><strong>Owner:</strong> <%= house.name %></p>
                        <p><strong>Price:</strong> <%= house.price %></p>
                        <p><%= house.description %></p>
                    </article>
                <% }) %>
            <% } %>
        </section>
    </main>

    <footer>
        <div class="footer-content">
            <p>&copy; <%= new Date().getFullYear() %> Home Listings. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>